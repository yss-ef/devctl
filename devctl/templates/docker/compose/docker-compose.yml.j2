# Generated by devctl dockerize.
# Copy .env.example to .env and fill required secret values before running:
# docker compose up --build

services:
{% if db %}
  database:
    image: {{ db.image }}
    restart: unless-stopped
{% if db.type == "postgres" %}
    environment:
      POSTGRES_DB: ${DB_NAME:-app}
      POSTGRES_USER: ${DB_USER:-app}
      POSTGRES_PASSWORD: ${DB_PASSWORD:?Set DB_PASSWORD in .env}
{% else %}
    environment:
      MYSQL_RANDOM_ROOT_PASSWORD: "true"
      MYSQL_DATABASE: ${DB_NAME:-app}
      MYSQL_USER: ${DB_USER:-app}
      MYSQL_PASSWORD: ${DB_PASSWORD:?Set DB_PASSWORD in .env}
{% endif %}
    volumes:
      - devctl_{{ db.type }}_data:{{ db.volume_path }}
    healthcheck:
      test: ["CMD-SHELL", "{{ db.healthcheck }}"]
      interval: 10s
      timeout: 5s
      retries: 10
{% endif %}
{% for service in services %}
  {{ service.name }}:
    build:
      context: "{{ service.context }}"
      dockerfile: Dockerfile
    restart: unless-stopped
{% if service.kind == "spring" %}
    environment:
      SERVER_PORT: "{{ service.environment.SERVER_PORT }}"
      JAVA_OPTS: "{{ service.java_opts_env }}"
      APPLICATION_SECURITY_JWT_SECRET_KEY: "{{ service.environment.APPLICATION_SECURITY_JWT_SECRET_KEY }}"
{% if service.environment.SPRING_DATASOURCE_URL is defined %}
      SPRING_DATASOURCE_URL: "{{ service.environment.SPRING_DATASOURCE_URL }}"
      SPRING_DATASOURCE_USERNAME: "{{ service.environment.SPRING_DATASOURCE_USERNAME }}"
      SPRING_DATASOURCE_PASSWORD: "{{ service.environment.SPRING_DATASOURCE_PASSWORD }}"
{% endif %}
{% endif %}
    ports:
      - "{{ service.port_mapping }}"
{% if service.depends_on_database %}
    depends_on:
      database:
        condition: service_healthy
{% elif service.depends_on_api %}
    depends_on:
      {{ service.depends_on_api }}:
        condition: service_started
{% endif %}
{% endfor %}
{% if db %}
volumes:
  devctl_{{ db.type }}_data:
{% endif %}
