# Generated by devctl dockerize.
server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

{% if api_upstream %}
    # Route frontend API calls to the Spring service inside the Compose network.
    location = /api {
        return 308 /api/;
    }

    location /api/ {
        proxy_pass http://{{ api_upstream }}:8080/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
{% else %}
    # No automatic /api proxy was generated because devctl did not detect exactly one backend.
{% endif %}
}
